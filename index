<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --red:#E01B16;--red-dark:#B51310;
  --blue:#1B4FD8;--blue-dark:#1340B0;
  --white:#FFFFFF;--off:#F4F3F1;
  --black:#0C0C0C;--black2:#161616;--black3:#1F1F1F;--gray:#2A2A2A;
  --D:'Bebas Neue',Impact,sans-serif;
  --B:'DM Sans',system-ui,sans-serif;
  --I:'Playfair Display',Georgia,serif;
}
html{scroll-behavior:smooth;}
body{font-family:var(--B);background:var(--black);color:var(--white);overflow-x:hidden;}
img{display:block;}
:focus-visible{outline:2px solid var(--red);outline-offset:3px;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;height:62px;transition:background .3s;}
nav.scrolled{background:rgba(12,12,12,.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.05);}
.nav-left{display:flex;align-items:center;gap:10px;}
.nav-logo{height:30px;filter:brightness(10);opacity:.9;}
.nav-name{font-family:var(--D);font-size:1.25rem;letter-spacing:.08em;color:var(--white);}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{font-size:.72rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.65);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--white);}
.nav-cta{background:var(--red)!important;color:var(--white)!important;padding:.42rem 1.1rem;}
.nav-cta:hover{background:var(--red-dark)!important;}
/* hamburger */
.nav-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto;}
.nav-hamburger span{display:block;width:22px;height:2px;background:var(--white);transition:all .25s;}
.nav-hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.nav-hamburger.open span:nth-child(2){opacity:0;}
.nav-hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.nav-mobile-menu{display:none;position:fixed;top:62px;left:0;right:0;background:rgba(12,12,12,.98);border-bottom:1px solid rgba(255,255,255,.06);padding:1.25rem 5vw 1.5rem;flex-direction:column;gap:.75rem;z-index:199;}
.nav-mobile-menu.open{display:flex;}
.nav-mobile-menu a{font-size:.8rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.6);text-decoration:none;padding:.45rem 0;border-bottom:1px solid rgba(255,255,255,.05);}
.nav-mobile-menu a:last-child{background:var(--red);color:var(--white);text-align:center;padding:.65rem;border-bottom:none;margin-top:.25rem;}

/* ── HERO ── */
.hero{position:relative;height:100vh;min-height:620px;display:flex;align-items:flex-end;overflow:hidden;}
.hero-bg{position:absolute;inset:0;z-index:0;}
.hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center top;filter:grayscale(15%);}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(12,12,12,.92) 45%,rgba(12,12,12,.35) 100%),linear-gradient(to top,rgba(12,12,12,.75) 25%,transparent 60%);}
.hero-content{position:relative;z-index:2;padding:0 5vw 7vh;max-width:1400px;margin:0 auto;width:100%;}
.hero-eyebrow{font-size:.68rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--red);display:flex;align-items:center;gap:.7rem;margin-bottom:1.1rem;}
.hero-eyebrow::before{content:'';width:24px;height:2px;background:var(--red);}
.hero-h1{font-family:var(--D);font-size:clamp(4.5rem,10vw,10rem);line-height:.85;letter-spacing:.02em;color:var(--white);margin-bottom:.15em;}
.hero-h1 .red{color:var(--red);}
.hero-tagline{font-family:var(--I);font-style:italic;font-size:clamp(1rem,1.8vw,1.3rem);color:rgba(255,255,255,.85);max-width:48ch;line-height:1.65;margin-bottom:2rem;}
.hero-pills{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:2.2rem;}
.pill{font-size:.63rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(255,255,255,.25);color:rgba(255,255,255,.75);padding:.28rem .75rem;}
.hero-btns{display:flex;gap:.75rem;flex-wrap:wrap;}
.btn-r{background:var(--red);color:var(--white);border:2px solid var(--red);padding:.88rem 2rem;font-family:var(--B);font-size:.76rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;display:inline-block;transition:background .2s;cursor:pointer;}
.btn-r:hover{background:var(--red-dark);border-color:var(--red-dark);}
.btn-o{background:transparent;color:var(--white);border:2px solid rgba(255,255,255,.4);padding:.88rem 2rem;font-family:var(--B);font-size:.76rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;display:inline-block;transition:all .2s;cursor:pointer;}
.btn-o:hover{border-color:var(--white);background:rgba(255,255,255,.06);}
.hero-scroll{position:absolute;right:5vw;bottom:40px;z-index:2;display:flex;flex-direction:column;align-items:center;gap:.5rem;}
.scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--red),transparent);animation:pulse 2s ease-in-out infinite;}
.scroll-txt{font-size:.6rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.45);}
@keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}
.hero-stats{position:absolute;bottom:0;right:0;z-index:3;display:flex;}
.hstat{background:var(--red);padding:1.1rem 2rem;display:flex;flex-direction:column;gap:.2rem;border-left:1px solid rgba(255,255,255,.1);}
.hstat:first-child{background:var(--blue);}
.hstat-n{font-family:var(--D);font-size:2rem;line-height:1;color:var(--white);}
.hstat-l{font-size:.6rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.75);}

/* mobile sticky CTA */
.sticky-cta{display:none;position:fixed;bottom:0;left:0;right:0;z-index:150;background:var(--red);color:var(--white);text-align:center;padding:.9rem;font-family:var(--B);font-size:.78rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;border-top:2px solid var(--red-dark);}

/* ── TICKER ── */
.ticker{background:var(--red);padding:.55rem 0;overflow:hidden;}
.ticker-track{display:flex;white-space:nowrap;animation:tick 22s linear infinite;}
.tick-item{font-family:var(--D);font-size:1rem;letter-spacing:.1em;color:var(--white);padding:0 2rem;}
.tick-dot{color:rgba(255,255,255,.5);padding:0;}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── CREDENCIALES ── */
.creds{padding:80px 5vw;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5vw;align-items:center;}
.sec-label{font-size:.67rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--red);}
.creds-title{font-family:var(--D);font-size:clamp(2.8rem,5vw,5rem);line-height:.88;letter-spacing:.02em;color:var(--white);margin:.4rem 0 1.5rem;}
.creds-title .bl{color:var(--blue);}
.creds-title .out{-webkit-text-stroke:1.5px rgba(255,255,255,.7);color:transparent;}
.creds-body{font-size:.95rem;color:rgba(255,255,255,.8);line-height:1.85;max-width:46ch;}
.creds-body em{font-style:italic;color:rgba(255,255,255,.95);}
.creds-quote{margin-top:2rem;border-left:3px solid var(--red);padding-left:1.1rem;}
.creds-quote p{font-family:var(--I);font-style:italic;font-size:1rem;color:rgba(255,255,255,.7);line-height:1.65;}
.creds-llamado{margin-top:1.5rem;}
.llamado-title{font-size:.62rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:.65rem;}
.llamado-list{list-style:none;display:flex;flex-direction:column;gap:.45rem;}
.llamado-list li{font-size:.85rem;color:rgba(255,255,255,.65);line-height:1.5;display:flex;gap:.6rem;}
.llamado-list li::before{content:'→';color:var(--red);flex-shrink:0;font-size:.75rem;margin-top:.1em;}
.creds-right{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.07);}
.cred-box{background:var(--black2);padding:1.75rem 1.5rem;display:flex;flex-direction:column;gap:.5rem;}
.cred-box.blue{background:var(--blue);}
.cred-box.red{background:var(--red);}
.cred-n{font-family:var(--D);font-size:2.8rem;line-height:1;color:var(--white);}
.cred-l{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.7);}

/* ── VIDEO ── */
.video-section{padding:100px 5vw;max-width:1400px;margin:0 auto;}
.vid-hdr{margin-bottom:40px;}
.vid-h{font-family:var(--D);font-size:clamp(2.5rem,4.5vw,4rem);line-height:.9;letter-spacing:.02em;color:var(--white);margin:.4rem 0 0;}
.vid-h .red{color:var(--red);}
.vid-embed-wrap{position:relative;width:100%;aspect-ratio:16/9;background:var(--black2);border:1px solid rgba(255,255,255,.07);overflow:hidden;}
.vid-embed-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none;}
.vid-placeholder{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;color:rgba(255,255,255,.35);}
.vid-play{width:64px;height:64px;border:2px solid rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;}
.vid-placeholder p{font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;}
.vid-cta{margin-top:1.5rem;}

/* ── TESTIMONIOS ── */
.testimonios{background:var(--black2);padding:100px 5vw;border-top:1px solid rgba(255,255,255,.05);border-bottom:1px solid rgba(255,255,255,.05);}
.test-inner{max-width:1400px;margin:0 auto;}
.test-hdr{margin-bottom:52px;}
.test-h{font-family:var(--D);font-size:clamp(2.5rem,4.5vw,4rem);line-height:.9;letter-spacing:.02em;color:var(--white);margin:.4rem 0 0;}
.test-h .red{color:var(--red);}
.test-pending{font-size:.85rem;color:rgba(255,255,255,.45);font-style:italic;margin-top:1.5rem;font-family:var(--I);border-left:2px solid rgba(255,255,255,.1);padding-left:1rem;}
/* cuando haya testimonios reales, quitar .test-pending y descomentar .test-grid */
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.06);margin-top:2rem;}
.test-card{background:var(--black2);padding:2.25rem 1.75rem;display:flex;flex-direction:column;gap:1rem;}
.test-quote-mark{font-family:var(--D);font-size:4rem;line-height:.6;color:var(--red);opacity:.4;}
.test-body{font-family:var(--I);font-style:italic;font-size:.97rem;color:rgba(255,255,255,.8);line-height:1.75;flex:1;}
.test-author{border-top:1px solid rgba(255,255,255,.07);padding-top:.9rem;display:flex;flex-direction:column;gap:.2rem;}
.test-name{font-size:.82rem;font-weight:600;color:rgba(255,255,255,.9);}
.test-role{font-size:.72rem;color:rgba(255,255,255,.5);letter-spacing:.04em;}

/* ── MINISTERIOS STRIP ── */
.min-strip{background:var(--black2);border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);}
.min-strip-inner{max-width:1400px;margin:0 auto;padding:0 5vw;display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:rgba(255,255,255,.06);}
.min-item{background:var(--black2);padding:1.5rem 1.25rem;display:flex;flex-direction:column;gap:.5rem;text-decoration:none;transition:background .2s;border-top:2px solid transparent;}
.min-item:hover,.min-item:focus-visible{background:var(--gray);border-top-color:var(--red);}
.min-n{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--red);}
.min-name{font-family:var(--D);font-size:.95rem;letter-spacing:.04em;color:var(--white);line-height:1.1;}
.min-arr{font-size:.65rem;color:rgba(255,255,255,.35);margin-top:auto;transition:color .2s;}
.min-item:hover .min-arr,.min-item:focus-visible .min-arr{color:var(--red);}

/* ── TEMAS ── */
.temas{padding:100px 5vw;max-width:1400px;margin:0 auto;}
.temas-hdr{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;margin-bottom:56px;}
.temas-h{font-family:var(--D);font-size:clamp(3rem,5.5vw,5.5rem);line-height:.88;letter-spacing:.02em;color:var(--white);}
.temas-h .red{color:var(--red);}
.temas-h .out{-webkit-text-stroke:1.5px rgba(255,255,255,.7);color:transparent;}
.temas-sub{font-size:.92rem;color:rgba(255,255,255,.65);line-height:1.8;}
.sec-label-dk{font-size:.67rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--red);}
.t-filters{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:32px;}
.tf{font-family:var(--B);font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.6);background:transparent;border:1px solid rgba(255,255,255,.15);padding:.38rem .85rem;cursor:pointer;transition:all .2s;}
.tf:hover,.tf.on{background:var(--red);color:var(--white);border-color:var(--red);}
/* grid de 2 columnas para 4 temas — en CSS, no inline */
.t-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;}
.t-card{position:relative;aspect-ratio:4/5;overflow:hidden;cursor:pointer;background:var(--black3);}
.t-card-bg{position:absolute;inset:0;background:var(--black3);transition:transform .5s;}
.t-card:hover .t-card-bg,.t-card:focus-visible .t-card-bg{transform:scale(1.04);}
.t-card[data-cat="liderazgo"] .t-card-bg{background:linear-gradient(135deg,#0a0a0a 0%,#E01B16 100%);}
.t-card[data-cat="formacion"] .t-card-bg{background:linear-gradient(135deg,#0d1a3a 0%,#1B4FD8 100%);}
.t-card[data-cat="crisis"] .t-card-bg{background:linear-gradient(135deg,#0a0a0a 0%,#3A5A7C 100%);}
.t-card[data-cat="legado"] .t-card-bg{background:linear-gradient(135deg,#1a1200 0%,#7C5A3A 100%);}
.t-card-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.85) 40%,rgba(0,0,0,.1) 100%);}
.t-card-content{position:absolute;inset:0;padding:1.5rem;display:flex;flex-direction:column;justify-content:flex-end;}
.t-num{font-family:var(--D);font-size:.8rem;letter-spacing:.12em;color:rgba(255,255,255,.4);margin-bottom:auto;}
.t-cat-tag{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--white);background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);padding:.2rem .55rem;align-self:flex-start;margin-bottom:.6rem;}
.t-title{font-family:var(--D);font-size:1.35rem;letter-spacing:.03em;color:var(--white);line-height:1.1;margin-bottom:.4rem;}
.t-verse{font-family:var(--I);font-style:italic;font-size:.75rem;color:rgba(255,255,255,.6);margin-bottom:.85rem;}
.t-cta{font-size:.63rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.55);display:flex;align-items:center;gap:.4rem;transition:color .2s;}
.t-card:hover .t-cta,.t-card:focus-visible .t-cta,.t-card.on .t-cta{color:var(--white);}
.t-icon{width:18px;height:18px;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:.75rem;flex-shrink:0;}
.t-card.on .t-card-overlay{background:linear-gradient(to top,rgba(0,0,0,.95) 60%,rgba(0,0,0,.4) 100%);}
.t-detail{grid-column:1/-1;background:var(--black2);border-top:3px solid var(--red);padding:2.5rem;display:none;}
.t-detail.vis{display:block;}
.td-grid{display:grid;grid-template-columns:260px 1fr;gap:3rem;align-items:start;}
.td-title{font-family:var(--D);font-size:2rem;letter-spacing:.03em;color:var(--white);line-height:1.05;}
.td-verse{font-family:var(--I);font-style:italic;font-size:.85rem;color:var(--blue);margin:.35rem 0 1.25rem;}
.td-mi label{display:block;font-size:.58rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.2rem;}
.td-mi span{font-size:.82rem;color:rgba(255,255,255,.7);}
.td-mi{margin-bottom:.9rem;}
.td-close{margin-top:1.5rem;background:none;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.55);font-family:var(--B);font-size:.65rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:.42rem .9rem;cursor:pointer;transition:all .2s;}
.td-close:hover{border-color:var(--red);color:var(--red);}
.td-desc{font-size:.92rem;color:rgba(255,255,255,.7);line-height:1.85;}
.td-block{margin-bottom:1.5rem;}
.td-block:last-child{margin-bottom:0;}
.td-block-label{font-size:.6rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:.5rem;}
.td-biblica{font-family:var(--I);font-style:italic;font-size:.95rem;color:rgba(255,255,255,.85);line-height:1.75;border-left:2px solid var(--red);padding-left:1rem;}
.td-pts{margin-top:0;list-style:none;display:flex;flex-direction:column;gap:.55rem;}
.td-pts li{display:flex;gap:.7rem;font-size:.87rem;color:rgba(255,255,255,.65);line-height:1.6;}
.td-pts li::before{content:'—';color:var(--red);flex-shrink:0;}

/* ── LIBROS ── */
.libros{background:var(--off);padding:100px 5vw;}
.libros-inner{max-width:1400px;margin:0 auto;}
.libros-hdr{margin-bottom:48px;}
.libros-h{font-family:var(--D);font-size:clamp(3rem,5vw,5rem);line-height:.88;letter-spacing:.02em;color:var(--black);}
.libros-h .red{color:var(--red);}
.sec-label-lt{font-size:.67rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--red);}
.libros-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(0,0,0,.08);}
.libro{text-decoration:none;display:flex;flex-direction:column;background:var(--white);transition:all .3s;border-top:3px solid transparent;}
.libro:hover,.libro:focus-visible{border-top-color:var(--red);}
.libro:hover .libro-img img{transform:scale(1.04);}
.libro-img{aspect-ratio:1/1;overflow:hidden;background:#e8e6e1;}
.libro-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
.libro-body{padding:1.5rem;}
.libro-num{font-family:var(--D);font-size:.78rem;color:var(--red);letter-spacing:.08em;margin-bottom:.3rem;}
.libro-title{font-family:var(--D);font-size:1.3rem;letter-spacing:.03em;color:var(--black);line-height:1.1;margin-bottom:.55rem;}
.libro-desc{font-size:.8rem;color:rgba(0,0,0,.55);line-height:1.65;margin-bottom:.65rem;}
.libro-link{font-size:.65rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(0,0,0,.4);display:flex;align-items:center;gap:.35rem;transition:color .2s;}
.libro:hover .libro-link{color:var(--red);}
.libro-link::after{content:'↗';}

/* ── AUDIENCIAS ── */
.audiencias{background:var(--blue);padding:100px 5vw;}
.aud-inner{max-width:1400px;margin:0 auto;}
.aud-label{font-size:.67rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.7);}
.aud-h{font-family:var(--D);font-size:clamp(3rem,6vw,6.5rem);line-height:.85;letter-spacing:.02em;color:var(--white);margin:.5rem 0 56px;}
.aud-h .out{-webkit-text-stroke:2px rgba(255,255,255,.45);color:transparent;}
.aud-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.12);}
.aud-card{background:var(--blue);padding:2.25rem 1.5rem;display:flex;flex-direction:column;gap:.7rem;transition:background .2s;}
.aud-card:hover{background:var(--blue-dark);}
.aud-icon{font-size:1.6rem;}
.aud-title{font-family:var(--D);font-size:1.25rem;letter-spacing:.04em;color:var(--white);line-height:1.1;}
.aud-txt{font-size:.82rem;color:rgba(255,255,255,.72);line-height:1.7;}

/* ── PROCESO ── */
.proceso{padding:100px 5vw;background:var(--black2);border-top:1px solid rgba(255,255,255,.05);}
.proceso-inner{max-width:1400px;margin:0 auto;}
.proceso-hdr{margin-bottom:56px;}
.proceso-h{font-family:var(--D);font-size:clamp(2.5rem,4.5vw,4rem);line-height:.9;letter-spacing:.02em;color:var(--white);margin:.4rem 0 0;}
.proceso-h .red{color:var(--red);}
.proceso-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.06);}
.paso{background:var(--black2);padding:2rem 1.5rem;display:flex;flex-direction:column;gap:.75rem;border-top:2px solid rgba(255,255,255,.07);transition:border-color .2s;}
.paso:hover{border-top-color:var(--red);}
.paso-num{font-family:var(--D);font-size:3.5rem;line-height:1;color:rgba(255,255,255,.08);}
.paso-title{font-family:var(--D);font-size:1.15rem;letter-spacing:.04em;color:var(--white);line-height:1.1;}
.paso-desc{font-size:.84rem;color:rgba(255,255,255,.62);line-height:1.7;}

/* ── INVITACION ── */
.invitacion{padding:100px 5vw;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
.inv-left{display:flex;flex-direction:column;gap:1.4rem;}
.inv-big{font-family:var(--D);font-size:clamp(3.5rem,6.5vw,7rem);line-height:.85;letter-spacing:.02em;color:var(--white);}
.inv-big .red{color:var(--red);}
.inv-big .out{-webkit-text-stroke:1.5px rgba(255,255,255,.3);color:transparent;}
.inv-sub{font-size:.94rem;color:rgba(255,255,255,.65);line-height:1.8;max-width:40ch;}
.inv-q{border-left:3px solid var(--red);padding-left:1rem;font-family:var(--I);font-style:italic;font-size:.95rem;color:rgba(255,255,255,.65);line-height:1.65;}
.inv-soc{display:flex;flex-wrap:wrap;gap:.4rem;}
.soc{font-size:.67rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.15);padding:.32rem .75rem;text-decoration:none;transition:all .2s;}
.soc:hover{border-color:var(--red);color:var(--red);}
.inv-form-wrap{background:var(--black2);border:1px solid rgba(255,255,255,.07);padding:2.5rem;}
.ift{font-family:var(--D);font-size:2rem;letter-spacing:.04em;color:var(--white);margin-bottom:1.5rem;}
.ift span{color:var(--red);}
.fg{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.85rem;}
.fg label{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.6);}
.fg input,.fg textarea,.fg select{font-family:var(--B);font-size:.87rem;color:var(--white);background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);padding:.58rem .82rem;outline:none;transition:border-color .2s;width:100%;}
.fg input:focus,.fg textarea:focus,.fg select:focus{border-color:var(--red);}
.fg select option{background:var(--black2);}
.fg textarea{resize:vertical;min-height:80px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;}
.fsub{width:100%;background:var(--red);color:var(--white);border:none;padding:.92rem;font-family:var(--B);font-size:.76rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;margin-top:.4rem;transition:background .2s;}
.fsub:hover{background:var(--red-dark);}
.fsub:disabled{opacity:.6;cursor:not-allowed;}
.fstatus{padding:.75rem;font-size:.82rem;margin-top:.5rem;display:none;}
.fstatus.sending{display:block;color:rgba(255,255,255,.6);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);}
.fstatus.success{display:block;color:#5FCF80;background:rgba(95,207,128,.07);border:1px solid rgba(95,207,128,.2);}
.fstatus.error{display:block;color:#E87070;background:rgba(232,112,112,.07);border:1px solid rgba(232,112,112,.2);}
.fstatus.unconfigured{display:block;color:rgba(255,220,100,.9);background:rgba(255,220,100,.06);border:1px solid rgba(255,220,100,.2);}
.fok{display:none;text-align:center;padding:3rem 0;}
.fok-icon{font-size:2.5rem;margin-bottom:.65rem;}
.fok-t{font-family:var(--D);font-size:1.8rem;letter-spacing:.04em;color:var(--white);}
.fok-s{font-size:.84rem;color:rgba(255,255,255,.55);margin-top:.4rem;}

/* ── FOOTER ── */
footer{background:#070707;border-top:1px solid rgba(255,255,255,.04);padding:3rem 5vw;}
.foot-top{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:2rem;margin-bottom:2rem;}
.foot-brand .fn{font-family:var(--D);font-size:1.6rem;letter-spacing:.07em;color:var(--white);}
.foot-brand .ft{font-family:var(--I);font-style:italic;font-size:.85rem;color:var(--red);margin-top:.2rem;}
.foot-nav{display:flex;gap:1.5rem;flex-wrap:wrap;}
.foot-nav a{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);text-decoration:none;transition:color .2s;}
.foot-nav a:hover{color:var(--white);}
.foot-bot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;border-top:1px solid rgba(255,255,255,.04);padding-top:1.5rem;}
.foot-copy{font-size:.62rem;color:rgba(255,255,255,.25);letter-spacing:.06em;}
.foot-bar{width:36px;height:3px;background:var(--red);}

/* ── ANIMATIONS ── */
.fu{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
.fu.vis{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}.d5{transition-delay:.5s}

/* ── RESPONSIVE ── */
@media(max-width:1050px){
