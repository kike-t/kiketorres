<script>
/* ══════════════════════════════════════════════
   CONFIGURACIÓN — editar antes de publicar
   ══════════════════════════════════════════════ */

/* VIDEO — pega el ID del video de YouTube aquí
   Ejemplo: si el URL es youtube.com/watch?v=abc123 → VIDEO_ID = "abc123"
   Déjalo vacío ("") para mostrar el placeholder */
const VIDEO_ID = "";

/* FORMULARIO — pega aquí el endpoint de tu servicio de formularios
   Opciones:
   · Formspree:      https://formspree.io/f/TU_ID
   · Netlify Forms:  usa el atributo netlify en el form (sin fetch)
   · Make/Zapier:    usa el webhook URL que te dan
   Déjalo vacío ("") para mostrar aviso de no configurado */
const FORM_ENDPOINT = "";

/* ══════════════════════════════════════════════
   FIN DE CONFIGURACIÓN — no editar abajo
   ══════════════════════════════════════════════ */

/* nav scroll */
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',window.scrollY>60);
},{passive:true});

/* hamburger mobile */
const ham=document.getElementById('navHamburger');
const mob=document.getElementById('navMobileMenu');
ham.addEventListener('click',()=>{
  const open=mob.classList.toggle('open');
  ham.classList.toggle('open',open);
  ham.setAttribute('aria-expanded',open);
});
mob.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{
  mob.classList.remove('open');
  ham.classList.remove('open');
  ham.setAttribute('aria-expanded','false');
}));

/* scroll animations */
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis');});},{threshold:.08});
document.querySelectorAll('.fu').forEach(el=>obs.observe(el));

/* video — muestra iframe si hay VIDEO_ID, placeholder si no */
if(VIDEO_ID){
  const wrap=document.getElementById('vidWrap');
  document.getElementById('vidPlaceholder').remove();
  const ifr=document.createElement('iframe');
  ifr.src=`https://www.youtube.com/embed/${VIDEO_ID}`;
  ifr.title='Mensaje del pastor Kike Torres';
  ifr.allow='accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';
  ifr.allowFullscreen=true;
  ifr.loading='lazy';
  wrap.appendChild(ifr);
}

/* topic data */
const TD=[
  {
    title:"Por qué caen los líderes",verse:"1 Corintios 9:24–27",cat:"Liderazgo",dur:"60–75 min",fmt:"Conferencia pastoral / Retiro de líderes / Seminario",
    biblica:'"¿No saben que los que corren en el estadio, todos en verdad corren, pero solo uno obtiene el premio? Corran de tal modo que ganen… golpeo mi cuerpo y lo hago mi esclavo, no sea que habiendo predicado a otros, yo mismo sea descalificado." (1 Corintios 9:24–27)',
    meta:"Formar líderes que permanezcan sanos y firmes en el ministerio, priorizando intimidad con Dios, disciplina espiritual y descanso bíblico para no caer ni ser descalificados.",
    pts:["La caída muchas veces no viene por falta de preparación, sino por descuidar lo esencial: el llamado primario es a intimidad, no a actividad.","El ministerio pastoral tiene dos piernas: la oración y el ministerio de la Palabra; si una falla, el líder cojea espiritualmente.","Un previo común a la caída es no reposar bíblicamente: el descanso no es lujo, es obediencia y protección para el alma."]
  },
  {
    title:"Líder correcto, rol correcto",verse:"Efesios 4:11",cat:"Formación de equipos",dur:"60–90 min",fmt:"Conferencia pastoral / Taller de liderazgo / Retiro de equipo",
    biblica:'"El mundo acostumbra desechar lo que está roto, pero Dios no tiende a usar a nadie que no haya roto primero." — Adrian Rogers',
    meta:"Formar líderes que sepan escoger y formar equipos con sabiduría espiritual: gente correcta, en el rol correcto, con el corazón correcto.",
    pts:["Es clave saber escoger: Dios usa personas, así que la selección de equipo es parte del liderazgo espiritual.","Antes de poner a alguien a servir en el nombre de Jesús, confirma que su relación con Jesús es real; si no, es demasiado arriesgado.","Un buen líder no solo elige talento: crea ecosistemas donde las personas practican sus dones y crecen con integridad, cultura y capacidad."]
  },
  {
    title:"Un problema, un funeral y 2 cosas a no olvidar",verse:"Génesis 42:9",cat:"Crisis y llamado",dur:"45–60 min",fmt:"Conferencia pastoral / Retiro / Evento de cuidado",
    biblica:'"José se acordó de los sueños que había tenido…" (Génesis 42:9, NBLA)',
    meta:"Formar líderes que atraviesen crisis sin perder su llamado, cuidando su corazón del resentimiento y aprendiendo dependencia total de Dios.",
    pts:["La mayor herida que dejó la crisis en muchos pastores fue el resentimiento; si no hay perdón, no habrá gracia para avanzar.","José tuvo que aprender lo que muchos líderes olvidamos rápido: dependencia total de Dios (para el alma, para tratar con otros y para los resultados).","Hay sueños que deben enterrarse: haz un funeral, llora, perdona… y levántate a cruzar a lo nuevo que Dios está haciendo."]
  },
  {
    title:"De intimidad a legado",verse:"Salmo 128:1–6",cat:"Legado",dur:"60–75 min",fmt:"Conferencia pastoral / Retiro familiar / Evento de cierre",
    biblica:'"Bienaventurado todo aquel que teme al Señor, que anda en Sus caminos… y veas a los hijos de tus hijos." (Salmo 128:1–6, NBLA)',
    meta:"Transformar la manera de ver la vida: pasar de perseguir lo que el mundo promete (éxito, comodidad, control, imagen) a abrazar lo que Dios quiere (temor del Señor, caminos del Reino, obediencia), para que la intimidad con Dios se traduzca en un legado real: una casa bendecida y generaciones alcanzadas.",
    pts:["El mundo promete bendición por rendimiento; Dios promete fruto por caminar en Sus caminos (temor del Señor + obediencia).","La intimidad con Dios no es un fin privado: es una raíz espiritual que inevitablemente se derrama en tu mesa, tu casa y tus hijos.","El legado no se hereda por discurso, sino por dirección: cuando Dios reina en ti, tu descendencia es alcanzada y bendecida."]
  }
];

/* topic card interactions */
let ap=null;
function closeDetail(){
  if(ap){ap.remove();ap=null;}
  document.querySelectorAll('.t-card.on').forEach(c=>{c.classList.remove('on');c.setAttribute('aria-expanded','false');c.querySelector('.t-icon').textContent='+';});
}
function openDetail(card,i){
  const d=TD[i];const g=document.getElementById('tGrid');
  closeDetail();
  card.classList.add('on');card.setAttribute('aria-expanded','true');card.querySelector('.t-icon').textContent='×';
  ap=document.createElement('div');ap.className='t-detail vis';ap.setAttribute('role','region');ap.setAttribute('aria-label','Detalle: '+d.title);
  const pts=d.pts.map(p=>`<li>${p}</li>`).join('');
  ap.innerHTML=`<div class="td-grid"><div><div class="td-title">${d.title}</div><div class="td-verse">${d.verse}</div><div class="td-mi"><label>Categoría</label><span>${d.cat}</span></div><div class="td-mi"><label>Duración estimada</label><span>${d.dur}</span></div><div class="td-mi"><label>Formato ideal</label><span>${d.fmt}</span></div><button class="td-close" onclick="closeDetail()">← Cerrar detalle</button></div><div><div class="td-block"><div class="td-block-label">Enfoque bíblico</div><p class="td-biblica">${d.biblica}</p></div><div class="td-block"><div class="td-block-label">Meta de la sesión</div><p class="td-desc">${d.meta}</p></div><div class="td-block"><div class="td-block-label">Puntos a considerar</div><ul class="td-pts">${pts}</ul></div></div></div>`;
  const cards=[...g.querySelectorAll('.t-card')];
  const ci=cards.indexOf(card);
  const cols=window.innerWidth<=700?1:2;
  const rowEnd=ci+cols-(ci%cols);
  const next=cards[rowEnd];
  if(next)g.insertBefore(ap,next);else g.appendChild(ap);
  setTimeout(()=>ap.scrollIntoView({behavior:'smooth',block:'nearest'}),80);
}
document.querySelectorAll('.t-card').forEach(c=>{
  c.addEventListener('click',()=>{c.classList.contains('on')?closeDetail():openDetail(c,parseInt(c.dataset.i));});
  c.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();c.classList.contains('on')?closeDetail():openDetail(c,parseInt(c.dataset.i));}});
});

/* filters */
document.querySelectorAll('.tf').forEach(b=>{
  b.addEventListener('click',()=>{
    closeDetail();
    document.querySelectorAll('.tf').forEach(x=>x.classList.remove('on'));
    b.classList.add('on');
    const f=b.dataset.f;
    document.querySelectorAll('.t-card').forEach(c=>{c.style.display=(f==='all'||c.dataset.cat===f)?'':'none';});
  });
});

/* form */
const fForm=document.getElementById('iForm');
const fBtn=document.getElementById('fBtn');
const fStatus=document.getElementById('fStatus');
const fOk=document.getElementById('fOk');

fForm.addEventListener('submit',async e=>{
  e.preventDefault();
  if(!FORM_ENDPOINT){
    fStatus.className='fstatus unconfigured';
    fStatus.textContent='El formulario aún no está conectado. Configura FORM_ENDPOINT al inicio del script para recibir solicitudes.';
    return;
  }
  fBtn.disabled=true;fBtn.textContent='Enviando...';
  fStatus.className='fstatus sending';fStatus.textContent='Enviando tu solicitud...';
  const body=Object.fromEntries(new FormData(fForm).entries());
  try{
    const res=await fetch(FORM_ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify(body)});
    if(res.ok){fForm.style.display='none';fStatus.style.display='none';fOk.style.display='block';}
    else throw new Error('Error '+res.status);
  }catch(err){
    fBtn.disabled=false;fBtn.textContent='Enviar solicitud →';
    fStatus.className='fstatus error';fStatus.textContent='Hubo un error al enviar. Intenta de nuevo o contáctanos directamente.';
  }
});
</script>
